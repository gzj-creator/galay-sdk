@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(GALAY_KERNEL_VERSION "@PROJECT_VERSION@")
set(GALAY_KERNEL_BACKEND "@GALAY_KERNEL_BACKEND@")

# 设置包含目录
set_and_check(GALAY_KERNEL_INCLUDE_DIR "@PACKAGE_CMAKE_INSTALL_PREFIX@/include/galay-kernel")

if(NOT TARGET concurrentqueue::concurrentqueue)
    set(_galay_kernel_concurrentqueue_hints
        "${GALAY_KERNEL_CONCURRENTQUEUE_INCLUDE_DIR}"
        "@PACKAGE_CMAKE_INSTALL_PREFIX@/include"
        "/opt/homebrew/include"
        "/usr/local/include"
        "/usr/include"
    )
    unset(GALAY_KERNEL_CONCURRENTQUEUE_INCLUDE_DIR CACHE)
    find_path(GALAY_KERNEL_CONCURRENTQUEUE_INCLUDE_DIR
        NAMES
            moodycamel/concurrentqueue.h
            moodycamel/blockingconcurrentqueue.h
        HINTS ${_galay_kernel_concurrentqueue_hints}
        PATH_SUFFIXES concurrentqueue
    )
    if(NOT GALAY_KERNEL_CONCURRENTQUEUE_INCLUDE_DIR)
        message(FATAL_ERROR
            "galay-kernel requires concurrentqueue headers. Set "
            "GALAY_KERNEL_CONCURRENTQUEUE_INCLUDE_DIR to the include prefix containing "
            "concurrentqueue/moodycamel/concurrentqueue.h")
    endif()

    add_library(concurrentqueue::concurrentqueue INTERFACE IMPORTED GLOBAL)
    set_target_properties(concurrentqueue::concurrentqueue PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${GALAY_KERNEL_CONCURRENTQUEUE_INCLUDE_DIR}"
    )
endif()

# 提供导入的目标
include("${CMAKE_CURRENT_LIST_DIR}/galay-kernel-targets.cmake")

# 设置别名以便于使用
if(NOT TARGET galay-kernel::galay-kernel)
    add_library(galay-kernel::galay-kernel ALIAS galay-kernel)
endif()

# 检查组件
check_required_components(galay-kernel)
