@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(galay-utils REQUIRED CONFIG)
find_dependency(galay-kernel 3.4.5 REQUIRED CONFIG)

if(@GALAY_HTTP_ENABLE_SSL@)
    find_dependency(galay-ssl REQUIRED CONFIG)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/galay-http-targets.cmake")

# 检查必需的组件
check_required_components(galay-http)

# 设置变量供其他项目使用
set(galay-http_FOUND TRUE)
set(galay-http_VERSION @PROJECT_VERSION@)
