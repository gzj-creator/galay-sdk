set(GALAY_REDIS_TARGETS_FILE "@GALAY_REDIS_TARGETS_FILE@")
if(NOT EXISTS "${GALAY_REDIS_TARGETS_FILE}")
    message(FATAL_ERROR "Galay targets file not found: ${GALAY_REDIS_TARGETS_FILE}")
endif()

file(READ "${GALAY_REDIS_TARGETS_FILE}" _galay_targets_content)
string(REGEX MATCH "INTERFACE_COMPILE_OPTIONS \"([^\"]*)\"" _galay_compile_match "${_galay_targets_content}")
if(_galay_compile_match)
    set(_galay_compile_string "${CMAKE_MATCH_1}")
    set(_galay_compile_opts ${_galay_compile_string})
    foreach(_galay_option IN LISTS _galay_compile_opts)
        if(NOT _galay_option)
            continue()
        endif()
        string(FIND "${_galay_option}" "galay-kernel" _idx)
        if(NOT _idx EQUAL -1)
            message(FATAL_ERROR "galay-redis still exports kernel include via ${_galay_option}")
        endif()
    endforeach()
endif()

string(REGEX MATCH "INTERFACE_LINK_LIBRARIES \"([^\"]*)\"" _galay_link_match "${_galay_targets_content}")
if(_galay_link_match)
    set(_galay_link_string "${CMAKE_MATCH_1}")
    if(_galay_link_string MATCHES "galay::galay-utils")
        message(FATAL_ERROR "galay-redis still exports galay-utils through INTERFACE_LINK_LIBRARIES")
    endif()
endif()
