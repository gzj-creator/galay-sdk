@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(galay-kernel 3.4.4 REQUIRED CONFIG)
find_dependency(spdlog REQUIRED)

set(GALAY_REDIS_ENABLE_SSL @GALAY_REDIS_ENABLE_SSL@)
if(GALAY_REDIS_ENABLE_SSL)
    find_dependency(galay-ssl 1.2.2 REQUIRED CONFIG)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/galay-redis-targets.cmake")

check_required_components(galay-redis)
